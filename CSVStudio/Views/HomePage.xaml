<Page
    x:Class="CSVStudio.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16" ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="4">
            <TextBlock Text="CSV Studio" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="Load a CSV file to get started." Opacity="0.7"/>
        </StackPanel>

        <!-- DROP AREA -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                AllowDrop="True"
                DragOver="DropArea_DragOver"
                Drop="DropArea_Drop">
            <StackPanel HorizontalAlignment="Center" Spacing="8" Orientation="Horizontal">
                <FontIcon Glyph="&#xE8E5;" FontSize="28" VerticalAlignment="Center"/>
                <TextBlock Text="Drop a CSV file here" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Text=" or " VerticalAlignment="Center" Opacity="0.6"/>
                <Button Content="Browse files..." Click="BrowseButton_Click" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- SIDEBAR -->
        <Border Grid.Row="2" Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
            <ScrollViewer>
                <StackPanel Spacing="16">

                    <StackPanel Spacing="4">
                        <TextBlock Text="File details" FontWeight="SemiBold" Opacity="0.9"/>
                        <TextBlock x:Name="FileNameText" Text="No file loaded" Opacity="0.85" TextWrapping="Wrap"/>
                        <TextBlock x:Name="FileStatsText" Opacity="0.7" FontSize="12"/>
                    </StackPanel>

                    <Border Background="{ThemeResource CardStrokeColorDefaultBrush}" Height="1" Opacity="0.4"/>

                    <StackPanel Spacing="12">
                        <TextBlock Text="Format" FontWeight="SemiBold" Opacity="0.9"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Encoding" FontSize="12" Opacity="0.7"/>
                            <ComboBox x:Name="EncodingCombo" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="UTF-8" Tag="utf-8"/>
                                <ComboBoxItem Content="UTF-8 with BOM" Tag="utf-8-bom"/>
                                <ComboBoxItem Content="UTF-16 LE" Tag="utf-16"/>
                                <ComboBoxItem Content="UTF-16 BE" Tag="utf-16BE"/>
                                <ComboBoxItem Content="Windows-1252 (ANSI)" Tag="windows-1252"/>
                                <ComboBoxItem Content="ISO-8859-1" Tag="iso-8859-1"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Separator" FontSize="12" Opacity="0.7"/>
                            <ComboBox x:Name="SeparatorCombo" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Comma (,)" Tag=","/>
                                <ComboBoxItem Content="Semicolon (;)" Tag=";"/>
                                <ComboBoxItem Content="Tab (\t)" Tag="\t"/>
                                <ComboBoxItem Content="Pipe (|)" Tag="|"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Quote character" FontSize="12" Opacity="0.7"/>
                            <ComboBox x:Name="QuoteCombo" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Double quote (&quot;)" Tag="&quot;"/>
                                <ComboBoxItem Content="Single quote (')" Tag="'"/>
                            </ComboBox>
                        </StackPanel>

                        <CheckBox x:Name="HasHeaderCheck" Content="First row is header" IsChecked="True"/>

                        <Button x:Name="ApplyButton"
                                Content="Apply"
                                HorizontalAlignment="Stretch"
                                Style="{ThemeResource AccentButtonStyle}"
                                Click="ApplyButton_Click"
                                IsEnabled="False"/>
                    </StackPanel>

                    <Border Background="{ThemeResource CardStrokeColorDefaultBrush}" Height="1" Opacity="0.4"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Auto-detection" FontWeight="SemiBold" Opacity="0.9"/>
                        <TextBlock x:Name="DetectionInfoText"
                                   Opacity="0.75"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   FontSize="12"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2" Grid.Column="1">
            <Pivot x:Name="MainPivot">

                <PivotItem Header="Preview">
                    <controls:DataGrid x:Name="PreviewGrid"
                                       AutoGenerateColumns="False"
                                       IsReadOnly="True"
                                       GridLinesVisibility="Horizontal"
                                       HeadersVisibility="Column"/>
                </PivotItem>

                <PivotItem Header="Statistics">
                    <controls:DataGrid x:Name="StatsGrid"
                                       AutoGenerateColumns="False"
                                       IsReadOnly="True"
                                       GridLinesVisibility="Horizontal"
                                       HeadersVisibility="Column">
                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn Header="Column"     Binding="{Binding ColumnName}"        Width="2*"/>
                            <controls:DataGridTextColumn Header="Type"       Binding="{Binding DetectedType}"      Width="*"/>
                            <controls:DataGridTextColumn Header="Empty"      Binding="{Binding EmptyValues}"       Width="*"/>
                            <controls:DataGridTextColumn Header="Empty %"    Binding="{Binding EmptyPercentage}"   Width="*"/>
                            <controls:DataGridTextColumn Header="Distinct"   Binding="{Binding DistinctValues}"    Width="*"/>
                            <controls:DataGridTextColumn Header="Duplicates" Binding="{Binding DuplicateValues}"   Width="*"/>
                            <controls:DataGridTextColumn Header="Min"        Binding="{Binding MinValue}"          Width="2*"/>
                            <controls:DataGridTextColumn Header="Max"        Binding="{Binding MaxValue}"          Width="2*"/>
                        </controls:DataGrid.Columns>
                    </controls:DataGrid>
                </PivotItem>

                <PivotItem Header="Operations">
                    <ScrollViewer>
                        <StackPanel Spacing="16" Padding="0,8,0,0">

                            <TextBlock Text="Cleanup operations"
                                       FontWeight="SemiBold"
                                       Opacity="0.9"/>

                            <ItemsControl x:Name="OperationsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="16,12"
                                                Margin="0,0,0,8">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <FontIcon Grid.Column="0"
                                                          Glyph="{Binding IconGlyph}"
                                                          FontSize="22"
                                                          VerticalAlignment="Center"/>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Opacity="0.7" FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Content="Apply"
                                                        Click="OperationApply_Click"
                                                        Tag="{Binding}"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Find &amp; Replace"
                                       FontWeight="SemiBold"
                                       Opacity="0.9"
                                       Margin="0,8,0,0"/>

                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Find" FontSize="12" Opacity="0.7"/>
                                        <TextBox x:Name="FindBox" HorizontalAlignment="Stretch"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Replace with" FontSize="12" Opacity="0.7"/>
                                        <TextBox x:Name="ReplaceBox" HorizontalAlignment="Stretch"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <CheckBox x:Name="MatchCaseCheck" Content="Match case"/>
                                        <CheckBox x:Name="UseRegexCheck" Content="Use regex"/>
                                    </StackPanel>

                                    <Button Content="Apply Find &amp; Replace"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="FindReplaceApply_Click"/>
                                </StackPanel>
                            </Border>

                            <InfoBar x:Name="OperationResultBar"
                                     IsOpen="False"
                                     Severity="Success"
                                     Margin="0,8,0,0"/>

                            <Button x:Name="ResetButton"
                                    Content="Reset to original"
                                    Click="ResetButton_Click"
                                    HorizontalAlignment="Stretch"/>

                            <Border Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Height="1" Opacity="0.4" Margin="0,8"/>

                            <TextBlock Text="Export"
                                       FontWeight="SemiBold"
                                       Opacity="0.9"/>

                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="12">

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Format" FontSize="12" Opacity="0.7"/>
                                        <ComboBox x:Name="ExportFormatCombo"
                                                  HorizontalAlignment="Stretch"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="CSV" Tag="csv"/>
                                            <ComboBoxItem Content="JSON" Tag="json"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Encoding (CSV)" FontSize="12" Opacity="0.7"/>
                                        <ComboBox x:Name="ExportEncodingCombo"
                                                  HorizontalAlignment="Stretch"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="UTF-8" Tag="utf-8"/>
                                            <ComboBoxItem Content="UTF-8 with BOM" Tag="utf-8-bom"/>
                                            <ComboBoxItem Content="UTF-16 LE" Tag="utf-16"/>
                                            <ComboBoxItem Content="Windows-1252 (ANSI)" Tag="windows-1252"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Separator (CSV)" FontSize="12" Opacity="0.7"/>
                                        <ComboBox x:Name="ExportSeparatorCombo"
                                                  HorizontalAlignment="Stretch"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Comma (,)" Tag=","/>
                                            <ComboBoxItem Content="Semicolon (;)" Tag=";"/>
                                            <ComboBoxItem Content="Tab" Tag="\t"/>
                                            <ComboBoxItem Content="Pipe (|)" Tag="|"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <Button Content="Save as..."
                                            Style="{ThemeResource AccentButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="ExportButton_Click"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </PivotItem>

                <PivotItem Header="Edit">
                    <Grid RowSpacing="12" Padding="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button x:Name="UndoButton" Content="Undo" Click="UndoButton_Click" IsEnabled="False">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="Control" Key="Z"/>
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button x:Name="RedoButton" Content="Redo" Click="RedoButton_Click" IsEnabled="False">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="Control" Key="Y"/>
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Border Width="1" VerticalAlignment="Stretch" Margin="4,2"
                                    Background="{ThemeResource CardStrokeColorDefaultBrush}"/>
                            <DropDownButton Content="Add">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Add Row Above" Click="AddRowAbove_Click"/>
                                        <MenuFlyoutItem Text="Add Row Below" Click="AddRowBelow_Click"/>
                                        <MenuFlyoutItem Text="Duplicate Row" Click="DuplicateRow_Click"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="Add Column Before" Click="AddColumnBefore_Click"/>
                                        <MenuFlyoutItem Text="Add Column After" Click="AddColumnAfter_Click"/>
                                        <MenuFlyoutItem Text="Duplicate Column" Click="DuplicateColumn_Click"/>
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <Button Content="Rename column" Click="RenameColumn_Click"/>
                            <DropDownButton Content="Delete">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Delete Selected Rows" Click="DeleteRowButton_Click"/>
                                        <MenuFlyoutItem Text="Delete Column" Click="DeleteColumn_Click"/>
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <TextBlock VerticalAlignment="Center" Opacity="0.7" FontSize="12"
                                       Text="Select a row/cell first. Double-click a cell to edit. Changes are included in Export."/>
                        </StackPanel>

                        <controls:DataGrid x:Name="EditGrid" Grid.Row="1"
                                           AutoGenerateColumns="False"
                                           IsReadOnly="False"
                                           SelectionMode="Extended"
                                           GridLinesVisibility="All"
                                           HeadersVisibility="Column"
                                           PreparingCellForEdit="EditGrid_PreparingCellForEdit"
                                           CellEditEnded="EditGrid_CellEditEnded"/>
                    </Grid>
                </PivotItem>

            </Pivot>
        </Grid>

    </Grid>
</Page>