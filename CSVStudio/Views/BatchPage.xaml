<Page
    x:Class="CSVStudio.Views.BatchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16" ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="4">
            <TextBlock Text="Batch processing" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="Apply the same operations to multiple CSV files at once."
                       Opacity="0.7"/>
        </StackPanel>

        <!-- SIDEBAR -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
            <ScrollViewer>
                <StackPanel Spacing="16">

                    <StackPanel Spacing="8">
                        <TextBlock Text="Operations to apply"
                                   FontWeight="SemiBold" Opacity="0.9"/>
                        <TextBlock Text="Select operations to run in sequence."
                                   FontSize="12" Opacity="0.7"
                                   TextWrapping="Wrap"/>

                        <ItemsControl x:Name="OperationsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              Tag="{Binding}"
                                              Margin="0,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            Height="1" Opacity="0.4"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Output"
                                   FontWeight="SemiBold" Opacity="0.9"/>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Output folder" FontSize="12" Opacity="0.7"/>
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OutputFolderText"
                                         Grid.Column="0"
                                         PlaceholderText="(same as source)"
                                         IsReadOnly="True"/>
                                <Button x:Name="PickFolderButton"
                                        Grid.Column="1"
                                        Content="..."
                                        Click="PickFolder_Click"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Suffix" FontSize="12" Opacity="0.7"/>
                            <TextBox x:Name="SuffixText" Text="_clean"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            Height="1" Opacity="0.4"/>

                    <Button x:Name="RunButton"
                            Content="Run batch"
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="RunButton_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Row="1" Grid.Column="1" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                <Button Content="Add files..." Click="AddFiles_Click"/>
                <Button Content="Add folder..." Click="AddFolder_Click"/>
                <Button Content="Clear list" Click="ClearList_Click"/>
                <TextBlock x:Name="FilesCountText"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Opacity="0.7"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    AllowDrop="True"
                    DragOver="FilesArea_DragOver"
                    Drop="FilesArea_Drop">
                <controls:DataGrid x:Name="JobsGrid"
                                   AutoGenerateColumns="False"
                                   IsReadOnly="True"
                                   GridLinesVisibility="Horizontal"
                                   HeadersVisibility="Column">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="" Binding="{Binding StatusIcon}" Width="40"/>
                        <controls:DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Detected" Binding="{Binding DetectedSummary}" Width="2*"/>
                        <controls:DataGridTextColumn Header="Status" Binding="{Binding StatusMessage}" Width="3*"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Border>

            <ProgressBar x:Name="BatchProgress"
                         Grid.Row="2"
                         Minimum="0"
                         Maximum="100"
                         Value="0"/>

            <Border Grid.Row="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <ScrollViewer x:Name="LogScroll">
                    <TextBlock x:Name="LogText"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Opacity="0.85"/>
                </ScrollViewer>
            </Border>
        </Grid>

    </Grid>
</Page>